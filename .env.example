# Laptop backend (copy these values to .env.local)
DEPLOYMENT_MODE=backend
WAHA_API_URL=http://127.0.0.1:3100
WAHA_API_KEY=replace-with-a-long-random-value
WAHA_SESSION_PROXY_URL=http://your-phone-or-proxy-ip:port
BACKEND_INTERNAL_URL=http://127.0.0.1:3101
DASHBOARD_PASSWORD=replace-with-a-strong-password
DASHBOARD_SESSION_SECRET=replace-with-a-random-session-secret
GATEWAY_SHARED_SECRET=replace-with-a-different-random-gateway-secret
# Optional but recommended: the static domain assigned in the ngrok dashboard
# NGROK_DOMAIN=your-static-domain.ngrok-free.app

# Vercel only
# DEPLOYMENT_MODE=frontend
# FRONTEND_GATEWAY_URL=https://api.example.com
# DASHBOARD_PASSWORD=the-same-dashboard-password
# DASHBOARD_SESSION_SECRET=the-same-random-session-secret
# GATEWAY_SHARED_SECRET=the-same-random-gateway-secret
DEPLOYMENT_MODE=frontend
FRONTEND_GATEWAY_URL=https://YOUR-NGROK-URL.ngrok-free.app
DASHBOARD_PASSWORD=نفس كلمة المرور
DASHBOARD_SESSION_SECRET=نفس القيمة الموجودة على اللابتوب
GATEWAY_SHARED_SECRET=نفس القيمة الموجودة على اللابتوب
